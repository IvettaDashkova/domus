# ── Database ────────────────────────────────────────────────────────────────
# Dev: local Docker Postgres on 5434 (5433 is used by the Locus project).
# Migrations run as the superuser role.
DATABASE_URL=postgres://postgres:postgres@localhost:5434/domus
# App connects as a NON-superuser role subject to RLS (no BYPASSRLS).
APP_DATABASE_URL=postgres://domus_app:domus_app@localhost:5434/domus
# Prod (Supabase): URL-encode special chars in the password. Set per Vercel
# env scope (Production / Preview / Development). Do NOT commit real values.

# ── OSRM (self-hosted, Docker) ───────────────────────────────────────────────
OSRM_URL=http://localhost:5001

# ── LLM (Gemini free tier) — wired in Phase 0, called from Phase 3 ───────────
GOOGLE_GENERATIVE_AI_API_KEY=

# ── Tracing (Langfuse) — optional in Phase 0 ─────────────────────────────────
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com

# ── Embeddings (local, Transformers.js) ──────────────────────────────────────
# Text model is LOCKED at bge-small-en-v1.5 (384-d). Do not change.
TEXT_EMBED_MODEL=Xenova/bge-small-en-v1.5
IMAGE_EMBED_MODEL=Xenova/clip-vit-base-patch32
